# GitHub Personal Access Token (read-only, public repos)
# Create at: GitHub → Settings → Developer Settings → Personal Access Tokens → Fine-grained
# Required permissions: Public Repositories (read-only)
VITE_GITHUB_TOKEN=your_token_here

# Formspree form ID for contact form email delivery
# Create at: https://formspree.io → New Form → copy the ID from the endpoint URL
# e.g. if endpoint is https://formspree.io/f/abcdefgh → ID is abcdefgh
VITE_FORMSPREE_ID=your_formspree_id_here
